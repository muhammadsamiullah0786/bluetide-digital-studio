<svg xmlns="http://www.w3.org/2000/svg" width="400" height="400">
  <defs>
    <radialGradient id="grad" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#ffc0cb;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#ff69b4;stop-opacity:1" />
    </radialGradient>
  </defs>
  <circle cx="200" cy="200" r="200" fill="url(#grad)"/>
  <circle cx="200" cy="200" r="180" fill="white" opacity="0.1"/>
  <text x="200" y="200" font-size="32" font-weight="bold" fill="white" text-anchor="middle" dy=".3em">Avatar</text>
</svg>